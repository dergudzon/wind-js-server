# Server port
PORT=7000

# CORS whitelist - comma-separated list of allowed origins
CORS_WHITELIST=http://localhost:63342,http://localhost:3000,http://localhost:4000

# NOAA GFS data source URL
NOAA_BASE_URL=https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_1p00.pl

# How many days back to search for GRIB data (default: 7)
HARVEST_DEPTH_DAYS=7

# Delay between NOAA requests in ms to avoid rate limiting (default: 2000)
REQUEST_DELAY_MS=2000

# User-Agent header for NOAA requests
REQUEST_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# How many days of JSON data to keep, older files are deleted (default: 30)
RETENTION_DAYS=30
